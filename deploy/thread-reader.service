[Unit]
Description=Thread Reader Web Service
After=network.target

[Service]
Type=simple
User=threadreader
Group=threadreader
WorkingDirectory=/opt/thread-reader
EnvironmentFile=/opt/thread-reader/deploy/thread-reader.env
ExecStart=/usr/bin/python3 /opt/thread-reader/thread_reader_server.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/thread-reader

[Install]
WantedBy=multi-user.target
